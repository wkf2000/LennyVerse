# LennyVerse environment variables
# Never commit real secrets.

# Optional override for frontend API base URL.
# Leave blank in production when FastAPI serves frontend + backend from the same origin.
# Set this for local frontend-only dev if needed.
VITE_API_BASE_URL=

# Optional: comma-separated origins allowed to call the API.
# Leave blank for same-origin deployments (recommended).
# Example for local cross-origin dev:
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGINS=

########################################
# Supabase
########################################
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_URL=



########################################
# Embeddings
########################################
# Embedding runtime endpoint
OLLAMA_EMBED_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=embeddinggemma
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=64

########################################
# RAG + OpenAI-compatible chat
########################################
# OpenAI-compatible base URL (OpenAI default shown)
OPENAI_API_BASE=https://api.openai.com/v1
# API key for chat/completions provider
OPENAI_API_KEY=
# Chat model used for answer generation
OPENAI_MODEL=gpt-4o-mini
# Retrieval defaults/limits
RAG_DEFAULT_K=8
RAG_MAX_K=32
# Timeout settings (seconds)
RAG_RETRIEVAL_TIMEOUT_SECONDS=30
RAG_CHAT_TIMEOUT_SECONDS=120


INGEST_CHUNK_SIZE_CHARS=1000
INGEST_CHUNK_OVERLAP_CHARS=100
DATASET_ROOT_DIR=data/lennys-newsletterpodcastdata

########################################
# Content Summarization
########################################
SUMMARIZE_API_BASE=
SUMMARIZE_API_KEY=
SUMMARIZE_MODEL=
SUMMARIZE_MAX_CHARS=8000

