# LennyVerse environment variables
# Copy this file to .env (or split into .env.app and .env.ingest locally).
# Never commit real secrets.

########################################
# App/API runtime
########################################
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

########################################
# Supabase
########################################
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=XXXX
SUPABASE_SECRET_KEY=YYYYY

########################################
# Neo4j
########################################
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

########################################
# Redis 
########################################
REDIS_URL=redis://localhost:6379/0

########################################
# Ollama endpoints + models
########################################
# Embedding runtime endpoint
OLLAMA_EMBED_BASE_URL=http://localhost:11434
# Extraction LLM runtime endpoint
OLLAMA_LLM_BASE_URL=http://localhost:11434
# Backward-compatible shared fallback (optional)
# OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=qwen3-embedding:0.6b
# LLM model for extraction stage (concepts/frameworks)
INGEST_EXTRACT_MODEL=llama3.1:8b
# Retries after structured output failures
INGEST_EXTRACT_RETRIES=2
# Keep deterministic extraction behavior
INGEST_EXTRACT_TEMPERATURE=0
# Timeout per extraction request
INGEST_EXTRACT_TIMEOUT_SEC=30
# Maximum chunk characters sent to extractor LLM
INGEST_EXTRACT_MAX_CHARS=2500

########################################
# Ingestion CLI (local-only execution)
########################################
# Filesystem path to raw archive input
INGEST_INPUT_DIR=./data/raw
# Optional output directory for run artifacts/logs
INGEST_OUTPUT_DIR=./data/ingest-output
# Comma-separated stages: parse,chunk,embed,extract,load,project
INGEST_STAGES=parse,chunk,embed,extract,load,project
# MarkdownTextSplitter: character-based sizing
INGEST_CHUNK_SIZE_CHARS=1000
INGEST_CHUNK_OVERLAP_CHARS=200
# Optional: full | newsletter | podcast | subset
INGEST_SCOPE=full

########################################
# Optional model controls / safety rails
########################################
# Set to 1 to skip external model calls in local smoke tests
INGEST_DRY_RUN=0
# Hard cap for one run to avoid surprise costs
INGEST_MAX_DOCS_PER_RUN=0
# Batch size for embedding calls
INGEST_EMBED_BATCH_SIZE=32
