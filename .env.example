# LennyVerse environment variables
# Copy this file to .env (or split into .env.app and .env.ingest locally).
# Never commit real secrets.

########################################
# App/API runtime
########################################
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

########################################
# Supabase
########################################
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=XXXX
SUPABASE_SECRET_KEY=YYYYY

########################################
# Neo4j
########################################
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

########################################
# Redis 
########################################
REDIS_URL=redis://localhost:6379/0

########################################
# Embeddings (Google API)
########################################
GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-001
# Must match pgvector column dimension in schema.
EMBEDDING_DIMENSION=768

########################################
# Ingestion CLI (local-only execution)
########################################
# Filesystem path to raw archive input
INGEST_INPUT_DIR=./data/raw
# Optional output directory for run artifacts/logs
INGEST_OUTPUT_DIR=./data/ingest-output
# Comma-separated stages: parse,chunk,embed,extract,load,project
INGEST_STAGES=parse,chunk,embed,extract,load,project
# Optional: full | newsletter | podcast | subset
INGEST_SCOPE=full

########################################
# Optional model controls / safety rails
########################################
# Set to 1 to skip external model calls in local smoke tests
INGEST_DRY_RUN=0
# Hard cap for one run to avoid surprise costs
INGEST_MAX_DOCS_PER_RUN=0
# Batch size for embedding calls
INGEST_EMBED_BATCH_SIZE=32
# Free-tier TPM (~30k/min) is easy to exceed on bulk ingest: minimum seconds between
# embedding requests (default 1.25 ≈ ~48 req/min; raise if you still see 429s).
INGEST_EMBED_MIN_INTERVAL_SEC=1.25
# On RESOURCE_EXHAUSTED / 429: sleep then retry (seconds); max attempts.
INGEST_EMBED_429_SLEEP_SEC=65
INGEST_EMBED_429_MAX_RETRIES=12
