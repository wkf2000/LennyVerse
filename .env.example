# LennyVerse environment variables
# Never commit real secrets.

# Browser → API: use a URL the *browser* can open (host port, HTTPS domain).
# Wrong: http://lennyverse-api:8000 (Docker DNS; fails from the browser with CORS/network errors)
# Right (example host map 8510:8000): http://localhost:8510 or https://api.your-domain
VITE_API_BASE_URL=http://localhost:8510

# Comma-separated origins allowed to call the API (must include your frontend origin)
CORS_ALLOW_ORIGINS=http://localhost:8511,http://127.0.0.1:8511,http://localhost:5173

########################################
# Supabase
########################################
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_URL=



########################################
# Embeddings
########################################
# Embedding runtime endpoint
OLLAMA_EMBED_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=embeddinggemma
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=64


INGEST_CHUNK_SIZE_CHARS=1000
INGEST_CHUNK_OVERLAP_CHARS=100
DATASET_ROOT_DIR=data/lennys-newsletterpodcastdata

